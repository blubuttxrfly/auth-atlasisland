{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["api/**/*", "_lib/**/*", "public/**/*"],
  "exclude": ["node_modules", "dist"]
}
