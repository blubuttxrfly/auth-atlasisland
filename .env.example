# Atlas Island Auth — Environment Variables
# Copy this file to .env for local development, or set these in Vercel project settings.

# Upstash Redis (REQUIRED)
UPSTASH_REDIS_REST_URL=https://.../upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=...

# Session signing (REQUIRED — generate with: openssl rand -hex 32)
AUTH_SESSION_SECRET=...

# Resend email service (REQUIRED for magic links)
RESEND_API_KEY=re_...
AUTH_EMAIL_FROM=Atlas Island <noreply@atlasisland.co>

# Resend Inbound Email Forwarding (optional)
# When Resend receives email at *@atlasisland.co, forward it here.
RESEND_INBOUND_FORWARD_TO=your-receiving-inbox@gmail.com
RESEND_WEBHOOK_SECRET=whsec_...  # From Resend webhook details page

# Optional: control cookie Secure flag behavior in non-production environments
# NODE_ENV=production
